{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System":    "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=dataspeak;Username=dataspeak_user;Password=${DB_PASSWORD}",
    "Redis":             "redis:6379,abortConnect=false"
  },
  "Jwt": {
    "Issuer":                    "dataspeak",
    "Audience":                  "dataspeak-users",
    "SecretKey":                 "${JWT_SECRET_KEY}",
    "AccessTokenExpiryMinutes":  15
  },
  "Claude": {
    "ApiKey":    "${CLAUDE_API_KEY}",
    "Model":     "claude-opus-4-6",
    "MaxTokens": 1024
  },
  "Encryption": {
    "MasterKey": "${ENCRYPTION_MASTER_KEY}"
  },
  "AllowedOrigins": [
    "https://app.dataspeak.io",
    "http://localhost:4200"
  ],
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests":       false,
    "RealIpHeader":               "X-Real-IP",
    "ClientIdHeader":             "X-ClientId",
    "HttpStatusCode":             429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period":   "1m",
        "Limit":    60
      },
      {
        "Endpoint": "POST:/api/queries/execute",
        "Period":   "1m",
        "Limit":    10
      },
      {
        "Endpoint": "POST:/api/auth/login",
        "Period":   "5m",
        "Limit":    5
      }
    ]
  }
}
