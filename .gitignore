# ============================================================
# DataSpeak .gitignore
# ============================================================

# --- Secrets & Environment ---
.env
*.env.local
*.env.production

# --- .NET Build Artifacts ---
[Bb]in/
[Oo]bj/
*.user
*.suo
*.vs/
.vs/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
TestResults/
*.coverage
*.coveragexml
nul

# --- ASP.NET ---
**/Properties/launchSettings.json

# --- Logs ---
logs/
*.log
Serilog/

# --- Node.js / Angular ---
node_modules/
dist/
.angular/
frontend/.angular/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
# (docker-compose.yml IS committed; .env is not)

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
*.swp
*.swo
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# --- Kubernetes secrets (example files are committed) ---
k8s/secrets.yaml

# --- Claude Code ---
.claude/settings.local.json
