# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=your_strong_db_password_here

# ── JWT ───────────────────────────────────────────────────────
# Must be at least 32 characters for HMAC-SHA256
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-chars

# ── Anthropic Claude ──────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── Encryption ────────────────────────────────────────────────
# Used for AES-256 encryption of stored connection strings
ENCRYPTION_MASTER_KEY=your-32-char-encryption-master-key
